# LocalBeacon.AI — Environment Variables
# Copy this file to .env.local and fill in the values
# Never commit .env.local to version control

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://localbeacon.ai

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Clerk (Auth) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ─── Anthropic (AI) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe (Payments) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe dashboard
STRIPE_SOLO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...
STRIPE_DFY_PRICE_ID=price_...

# ─── Resend (Email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...

# ─── Google Search Console ───────────────────────────────────────────────────
GOOGLE_GSC_CLIENT_ID=your-google-oauth-client-id
GOOGLE_GSC_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_GSC_REDIRECT_URI=https://localbeacon.ai/api/gsc/callback

# ─── Cron Security ───────────────────────────────────────────────────────────
# Random secret used to authenticate Vercel cron job requests
CRON_SECRET=your-random-cron-secret

# ─── Analytics (Optional) ────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
